# ── Supabase ──────────────────────────────────────────────────
# Create a project at https://supabase.com, then copy the Project URL
# and the anon (public) key from Settings > API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Admin authentication ───────────────────────────────────────
# When Supabase is configured, admin login uses Supabase Auth
# (create a user in Authentication > Users in the Supabase Dashboard).
# Without Supabase, this password is used as a dev-only fallback.
VITE_ADMIN_PASSWORD=change-me-in-production

# ── Contact form email delivery (Vercel API) ──────────────────
# Create an API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Verified sender domain mailbox (Resend)
CONTACT_FROM_EMAIL=no-reply@bmgdanismanlik.com
# Optional hard override recipient
CONTACT_TO_EMAIL=info@bmgdanismanlik.com